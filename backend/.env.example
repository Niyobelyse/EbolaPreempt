SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank for local SQLite; set to Neon connection string for production
DATABASE_URL=

# Frontend URL(s) allowed to call the API (comma-separated)
CORS_ALLOWED_ORIGINS=

# Used by build.sh to create the superuser on first deploy
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@ebolapreempt.com
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
